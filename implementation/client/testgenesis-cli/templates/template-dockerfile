# Stage 1: Build
FROM node:22-slim AS build
WORKDIR /workspace

# 1. Copy specification for proto generation
COPY specification /specification

# 2. Pre-cache shared library dependencies
COPY implementation/client/testgenesis-client-node/package*.json /workspace/testgenesis-client-node/
WORKDIR /workspace/testgenesis-client-node
RUN npm install

# 3. Build shared library
COPY implementation/client/testgenesis-client-node /workspace/testgenesis-client-node
RUN npm run build

# 4. Pre-cache agent dependencies
WORKDIR /workspace/agent
COPY package*.json /workspace/agent/
RUN npm install

# 5. Build agent
COPY . /workspace/agent
RUN npm run build

# Stage 2: Runtime
FROM node:22-slim
WORKDIR /app

# Copy built library and agent
COPY --from=build /workspace/testgenesis-client-node /app/testgenesis-client-node
COPY --from=build /workspace/agent /app/agent

WORKDIR /app/agent

# Default environment variables
ENV HUB_URL=http://cms:9000
ENV CLIENT_NAME=DockerAgent

# Run the compiled JavaScript directly with Node
CMD ["node", "dist/index.js"]
