{{> header}}

<div class="dashboard">
    <section>
        <div class="section-header">
            <h1>Payload Management</h1>
            <a href="/payloads/new" class="btn btn-primary">+ New Payload</a>
        </div>

        <div class="card" style="margin-top: 1rem;">
            <div class="card-body">
                <table class="data-table">
                    <thead>
                    <tr>
                        <th>ID</th>
                        <th>Payload Type</th>
                        <th>Attachments</th>
                        <th>Actions</th>
                    </tr>
                    </thead>
                    <tbody>
                    {{#payloads}}
                        <tr>
                            <td><code class="code-id">#{{id}}</code></td>
                            <td style="font-weight: 500;">{{type}}</td>
                            <td class="text-secondary">{{attachmentCount}} files</td>
                            <td>
                                <div class="action-buttons">
                                    <button class="btn btn-secondary" onclick="location.href='/payloads/edit/{{id}}'">
                                        Edit
                                    </button>
                                    <form action="/payloads/delete/{{id}}" method="POST" style="display:inline;"
                                          onsubmit="return confirm('Delete this payload and all its attachments?')">
                                        <button type="submit" class="btn btn-danger"
                                                style="color: var(--danger); border-color: var(--danger);">Delete
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    {{/payloads}}
                    {{^payloads}}
                        <tr>
                            <td colspan="4" class="empty-row">No payloads available. Click "New Payload" to start.</td>
                        </tr>
                    {{/payloads}}
                    </tbody>
                </table>
            </div>
        </div>
    </section>
</div>

{{> footer}}
