{{> header}}

<div class="dashboard">
    <section>
        <div class="section-header">
            <h1>Tests Repository</h1>
            <a href="/tests/new" class="btn btn-primary">+ New Test Project</a>
        </div>

        <div class="card" style="margin-top: 1rem;">
            <div class="card-body">
                <table class="data-table">
                    <thead>
                    <tr>
                        <th>ID</th>
                        <th>Name</th>
                        <th>Type</th>
                        <th>Payloads</th>
                        <th>Actions</th>
                    </tr>
                    </thead>
                    <tbody>
                    {{#tests}}
                        <tr>
                            <td><code class="code-id">#{{id}}</code></td>
                            <td style="font-weight: 500;">{{name}}</td>
                            <td><span class="badge">{{testType}}</span></td>
                            <td class="text-secondary">{{payloadCount}} items</td>
                            <td>
                                <div class="action-buttons">
                                    <button class="btn" onclick="location.href='/tests/run/{{id}}'">Execute</button>
                                    <button class="btn btn-secondary" onclick="location.href='/tests/edit/{{id}}'">
                                        Edit
                                    </button>
                                    <form action="/tests/delete/{{id}}" method="POST" style="display:inline;"
                                          onsubmit="return confirm('Delete this test project?')">
                                        <button type="submit" class="btn btn-danger"
                                                style="color: var(--danger); border-color: var(--danger);">Delete
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    {{/tests}}
                    {{^tests}}
                        <tr>
                            <td colspan="5" class="empty-row">No test projects found in repository.</td>
                        </tr>
                    {{/tests}}
                    </tbody>
                </table>
            </div>
        </div>
    </section>
</div>

{{> footer}}
