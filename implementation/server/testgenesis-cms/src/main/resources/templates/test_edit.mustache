{{> header}}

<div class="dashboard">
    <section>
        <div class="breadcrumb">
            <a href="/tests">Tests Repository</a> / {{#isEdit}}
            Edit Test{{/isEdit}}{{^isEdit}}New Test Project{{/isEdit}}
        </div>

        <div class="section-header">
            <h1>{{#isEdit}}Edit Test: {{test.name}}{{/isEdit}}{{^isEdit}}New Test Project{{/isEdit}}</h1>
        </div>

        <div class="card" style="max-width: 800px;">
            <div class="card-body">
                <form action="/tests/save" method="POST" class="form-group">
                    {{#isEdit}}
                        <input type="hidden" name="id" value="{{test.id}}">
                    {{/isEdit}}

                    <div class="info-item">
                        <label class="info-label">Project Name</label>
                        <input type="text" name="name" class="form-select" value="{{test.name}}"
                               placeholder="e.g. Finance API Regression" required>
                    </div>

                    <div class="info-item" style="margin-top: 1.5rem;">
                        <label class="info-label">Test Type</label>
                        <input type="text" name="testType" class="form-select" value="{{test.testType}}"
                               placeholder="e.g. functional, performance" required>
                    </div>

                    <div class="info-item" style="margin-top: 1.5rem;">
                        <label class="info-label">Associated Payloads</label>
                        <div class="text-secondary" style="font-size: 0.75rem; margin-bottom: 0.5rem;">
                            Select one or more payloads to include in this test project.
                        </div>
                        <select name="payloadIds" class="form-select" style="height: 200px;" multiple required>
                            {{#availablePayloads}}
                                <option value="{{id}}" {{#selected}}selected{{/selected}}>{{name}} ({{type}})</option>
                            {{/availablePayloads}}
                        </select>
                    </div>

                    <div class="action-buttons"
                         style="margin-top: 2rem; border-top: 1px solid var(--border); padding-top: 1.5rem;">
                        <button type="submit" class="btn btn-primary">Save Project</button>
                        <a href="/tests" class="btn">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </section>
</div>

{{> footer}}
