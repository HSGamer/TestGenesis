{{> me/hsgamer/testgenesis/cms/web/header.mustache}}

<div class="dashboard">
    <section>
        <div class="section-header">
            <h1>Management Dashboard</h1>
        </div>
        
        <div class="dashboard-grid">
            <!-- Agents Section -->
            <div class="card">
                <div class="card-header">
                    <h2>Connected Agents</h2>
                </div>
                <div class="card-body">
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>Agent</th>
                                <th>Capabilities</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {{#agents}}
                            <tr>
                                <td>
                                    <div style="font-weight: 500;">{{displayName}}</div>
                                    <code class="code-id" style="font-size: 0.7rem;">{{id}}</code>
                                </td>
                                <td>
                                    <span class="badge">{{capabilities}}</span>
                                </td>
                                <td>
                                    <div class="action-buttons">
                                        <button class="btn" onclick="location.href='/tests/run?agentId={{id}}'">Run Test</button>
                                        {{#canTranslate}}
                                        <button class="btn btn-primary" onclick="toggleTranslationBox('{{id}}')">Translate</button>
                                        {{/canTranslate}}
                                    </div>

                                    {{#canTranslate}}
                                    <div id="translation-box-{{id}}" class="translation-box" style="display:none;">
                                        <form action="/translate" method="GET">
                                            <input type="hidden" name="agentId" value="{{id}}">
                                            <div class="form-group">
                                                <select name="testId" class="form-select" required>
                                                    <option value="" disabled selected>Source Test Project</option>
                                                    {{#tests}}
                                                    <option value="{{id}}">{{name}}</option>
                                                    {{/tests}}
                                                </select>
                                                <select name="targetFormat" class="form-select" required>
                                                    <option value="" disabled selected>Target Format</option>
                                                    {{#targetFormats}}
                                                    <option value="{{.}}">{{.}}</option>
                                                    {{/targetFormats}}
                                                </select>
                                                <button type="submit" class="btn btn-primary" style="width: 100%;">Start Translation</button>
                                            </div>
                                        </form>
                                    </div>
                                    {{/canTranslate}}
                                </td>
                            </tr>
                            {{/agents}}
                            {{^agents}}
                            <tr>
                                <td colspan="3" class="empty-row">No active agents connected.</td>
                            </tr>
                            {{/agents}}
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Recent Results Section -->
            <div class="card">
                <div class="card-header">
                    <h2>Recent Executions</h2>
                    <a href="/tests" class="link-more">View all</a>
                </div>
                <div class="card-body">
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Test</th>
                                <th>Agent</th>
                                <th>Status</th>
                                <th>Timestamp</th>
                            </tr>
                        </thead>
                        <tbody>
                            {{#recentResults}}
                            <tr>
                                <td><code class="code-id">#{{id}}</code></td>
                                <td style="font-weight: 500;">{{testName}}</td>
                                <td>{{agentName}}</td>
                                <td>
                                    <div style="display: flex; align-items: center;">
                                        <span class="status-indicator status-{{status}}"></span>
                                        <span>{{status}}</span>
                                    </div>
                                </td>
                                <td class="text-secondary">{{registeredAt}}</td>
                            </tr>
                            {{/recentResults}}
                            {{^recentResults}}
                            <tr>
                                <td colspan="5" class="empty-row">No execution history available.</td>
                            </tr>
                            {{/recentResults}}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </section>
</div>

<script>
function toggleTranslationBox(agentId) {
    const box = document.getElementById('translation-box-' + agentId);
    box.style.display = box.style.display === 'none' ? 'block' : 'none';
}
</script>

