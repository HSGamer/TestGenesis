{
  "name": "uap-node",
  "version": "1.0.0-SNAPSHOT",
  "description": "Universal Agent Protocol (UAP) v1 Streamlined Node.js Library",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "generate-proto": "rm -rf src/generated && mkdir -p src/generated && npx buf generate ../../specification && node scripts/generate-index.js",
    "build": "npm run generate-proto && tsc",
    "clean": "rm -rf dist src/generated"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^1.10.0",
    "@connectrpc/connect": "^1.6.1",
    "@connectrpc/connect-node": "^1.6.1"
  },
  "devDependencies": {
    "@bufbuild/buf": "^1.50.0",
    "@bufbuild/protoc-gen-es": "^1.10.0",
    "@connectrpc/protoc-gen-connect-es": "^1.6.1",
    "typescript": "^5.7.3",
    "@types/node": "^22.13.9"
  }
}
